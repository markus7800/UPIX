fun draw(xs: list(bool), obs: bool, N: int(5)) {
    let d = pickball(N) in
    let x = index(d, xs) in
    let y = if x then flip 0.8 else flip 0.2 in
    observe(y <=> obs)
}

let N1 = discrete(0.002478894736996278, 0.014873376804367264, 0.04462011923658233, 0.08924017141404789, 0.1338602645720848, 0.16063232046690695, 0.16063224595677722, 0.13768480992385723, 0.10326375273764593, 0.06884230064774698, 0.04130536101601445, 0.022530227737925186, 0.011265109212079483, 0.005199273078993741, 0.0022282603566856287, 0.0008913061800606116, 0.00033423919903044144, 0.00011796672219757568, 0.0, 0.0) in
