let xs = [flip 0.5, flip 0.5, flip 0.5, flip 0.5, flip 0.5, flip 0.5, flip 0.5, flip 0.5, flip 0.5, flip 0.5, flip 0.5] in

let tmp = draw(xs, true, N) in
let tmp = draw(xs, false, N) in
let tmp = draw(xs, true, N) in
