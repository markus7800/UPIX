
fun index(n: int(5), xs: list(bool)): bool {
    if n == int(5,0) then
        head xs
    else
        index(n - int(5, 1), tail xs)
}

fun pickball(N: int(5)): int(5) {
    if N == int(5,0) then int(5,0)
    else if N == int(5, 1) then int(5,0)
    else if N == int(5,2) then uniform(5,0,2)
    else if N == int(5,3) then uniform(5,0,3)
    else if N == int(5,4) then uniform(5,0,4)
    else if N == int(5,5) then uniform(5,0,5)
    else if N == int(5,6) then uniform(5,0,6)
    else if N == int(5,7) then uniform(5,0,7)
    else if N == int(5,8) then uniform(5,0,8)
    else if N == int(5,9) then uniform(5,0,9)
    else if N == int(5,10) then uniform(5,0,10)
    else if N == int(5,11) then uniform(5,0,11)
    else if N == int(5,12) then uniform(5,0,12)
    else if N == int(5,13) then uniform(5,0,13)
    else if N == int(5,14) then uniform(5,0,14)
    else if N == int(5,15) then uniform(5,0,15)
    else if N == int(5,16) then uniform(5,0,16)
    else if N == int(5,17) then uniform(5,0,17)
    else if N == int(5,18) then uniform(5,0,18)
    else if N == int(5,19) then uniform(5,0,19)
    else if N == int(5,20) then uniform(5,0,20)
    else int(5,0)
}

fun draw(xs: list(bool), obs: bool, N: int(5)) {
    let d = pickball(N) in
    let x = index(d, xs) in
    observe(if x <=> obs then flip 0.8 else flip 0.2)
}

