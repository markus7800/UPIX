
fun index(N: int(5), x0: bool, x1: bool, x2: bool, x3: bool, x4: bool, x5: bool, x6: bool, x7: bool, x8: bool, x9: bool, x10: bool, x11: bool, x12: bool, x13: bool, x14: bool, x15: bool, x16: bool, x17: bool, x18: bool, x19: bool, x20: bool): bool {
    if N == int(5,0) then x0
    else if N == int(5,1) then x1
    else if N == int(5,2) then x2
    else if N == int(5,3) then x3
    else if N == int(5,4) then x4
    else if N == int(5,5) then x5
    else if N == int(5,6) then x6
    else if N == int(5,7) then x7
    else if N == int(5,8) then x8
    else if N == int(5,9) then x9
    else if N == int(5,10) then x10
    else if N == int(5,11) then x11
