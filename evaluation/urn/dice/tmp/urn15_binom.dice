
fun pickballs(N: int(4)): int(4) {
    if N == int(4,0) then int(4,0)
    else if N == int(4,1) then binomial(4,1,0.5)
    else if N == int(4,2) then binomial(4,2,0.5)
    else if N == int(4,3) then binomial(4,3,0.5)
    else if N == int(4,4) then binomial(4,4,0.5)
    else if N == int(4,5) then binomial(4,5,0.5)
    else if N == int(4,6) then binomial(4,6,0.5)
    else if N == int(4,7) then binomial(4,7,0.5)
    else if N == int(4,8) then binomial(4,8,0.5)
    else if N == int(4,9) then binomial(4,9,0.5)
    else if N == int(4,10) then binomial(4,10,0.5)
    else if N == int(4,11) then binomial(4,11,0.5)
    else if N == int(4,12) then binomial(4,12,0.5)
    else if N == int(4,13) then binomial(4,13,0.5)
    else if N == int(4,14) then binomial(4,14,0.5)
    else if N == int(4,15) then binomial(4,15,0.5)
    else int(4, 0)
}

