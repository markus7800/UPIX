fun index(n: int(4), x0: bool, x1: bool, x2: bool, x3: bool, x4: bool, x5: bool, x6: bool, x7: bool, x8: bool, x9: bool, x10: bool, x11: bool, x12: bool, x13: bool, x14: bool, x15: bool): bool {
    if n == int(4,0) then x0
    else if n == int(4,1) then x1
    else if n == int(4,2) then x2
    else if n == int(4,3) then x3
    else if n == int(4,4) then x4
    else if n == int(4,5) then x5
    else if n == int(4,6) then x6
    else if n == int(4,7) then x7
    else if n == int(4,8) then x8
    else if n == int(4,9) then x9
    else if n == int(4,10) then x10
    else if n == int(4,11) then x11
    else if n == int(4,12) then x12
    else if n == int(4,13) then x13
    else if n == int(4,14) then x14
    else x15
}

fun pickball(N: int(4)): int(4) {
    if N == int(4,0) then int(4,0)
    else if N == int(4, 1) then int(4,0)
    else if N == int(4,2) then uniform(4,0,2)
    else if N == int(4,3) then uniform(4,0,3)
    else if N == int(4,4) then uniform(4,0,4)
    else if N == int(4,5) then uniform(4,0,5)
    else if N == int(4,6) then uniform(4,0,6)
    else if N == int(4,7) then uniform(4,0,7)
    else if N == int(4,8) then uniform(4,0,8)
    else if N == int(4,9) then uniform(4,0,9)
    else if N == int(4,10) then uniform(4,0,10)
    else if N == int(4,11) then uniform(4,0,11)
    else if N == int(4,12) then uniform(4,0,12)
    else if N == int(4,13) then uniform(4,0,13)
    else if N == int(4,14) then uniform(4,0,14)
    else if N == int(4,15) then uniform(4,0,15)
    else int(4, 0)
}

fun draw_true(N: int(4), x0: bool, x1: bool, x2: bool, x3: bool, x4: bool, x5: bool, x6: bool, x7: bool, x8: bool, x9: bool, x10: bool, x11: bool, x12: bool, x13: bool, x14: bool, x15: bool) {
    let d = pickball(N) in
    let x = index(d, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    observe(if x then flip 0.8 else flip 0.2)
}

fun draw_false(N: int(4), x0: bool, x1: bool, x2: bool, x3: bool, x4: bool, x5: bool, x6: bool, x7: bool, x8: bool, x9: bool, x10: bool, x11: bool, x12: bool, x13: bool, x14: bool, x15: bool) {
    let d = pickball(N) in
    let x = index(d, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    observe(if x then flip 0.2 else flip 0.8)
}

// Bundle all 10 draws into a single execution path
fun run_all(n: int(4), x0: bool, x1: bool, x2: bool, x3: bool, x4: bool, x5: bool, x6: bool, x7: bool, x8: bool, x9: bool, x10: bool, x11: bool, x12: bool, x13: bool, x14: bool, x15: bool): bool {
    let tmp = draw_true(n, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    let tmp = draw_false(n, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    let tmp = draw_true(n, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    let tmp = draw_false(n, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    let tmp = draw_true(n, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    let tmp = draw_false(n, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    let tmp = draw_true(n, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    let tmp = draw_false(n, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    let tmp = draw_true(n, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    let tmp = draw_false(n, x0, x1, x2, x3, x4, x5, x6, x7, x8, x9, x10, x11, x12, x13, x14, x15) in
    true
}

